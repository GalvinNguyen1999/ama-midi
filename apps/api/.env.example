NODE_ENV=development
PORT=3000
# DATABASE (matches docker-compose.yml postgres service)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ama_midi
DATABASE_USERNAME=ama
DATABASE_PASSWORD=ama
DATABASE_URL= `postgresql://${DATABASE_USERNAME}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}`
LOG_LEVEL=info
CORS_ORIGINS="http://localhost:5173,https://your-frontend.app"
FRONTEND_BASE_URL="http://localhost:5173"
